# Music server — copia a .env para desarrollo local.
# NUNCA commitees secretos reales (.env está en .gitignore; este .example sí va al repo).

# Puerto del servidor
PORT=3000

# Raíz de la biblioteca musical.
#   - Dev local (Windows): C:\Musica
#   - Producción (Docker): /music  (montado read-only desde /mnt/storage)
MUSIC_DIR=C:\Musica

# Secreto para firmar los JWT. Genera uno fuerte con:
#   openssl rand -base64 48
JWT_SECRET=change-me-in-production

# Registro público de usuarios. Cerrado por defecto: los usuarios se crean solos
# vía Cloudflare Access (auto-provisioning). Ponlo en "true" solo temporalmente
# si necesitas crear un usuario con contraseña desde el formulario.
ALLOW_REGISTRATION=false

# --- Auto-login vía Cloudflare Access (opcional) ---
# Si ambas están definidas, la app canjea la identidad verificada por Cloudflare
# (JWT firmado) por su propio token, saltándose el login. Si faltan, el auto-login
# queda DESACTIVADO y solo funciona el login por contraseña (p.ej. en red local).
#   - CF_ACCESS_TEAM_DOMAIN: tu dominio de equipo Zero Trust (sin barra final).
#   - CF_ACCESS_AUD: el "Application Audience (AUD) Tag" de la app en Access.
CF_ACCESS_TEAM_DOMAIN=https://tuequipo.cloudflareaccess.com
CF_ACCESS_AUD=

# --- Solo despliegue (Dokploy / docker-compose), NO se usa en dev local ---
# Token del túnel de Cloudflare (modo token). Lo lee el servicio "cloudflared"
# del docker-compose.yml. Defínelo en las env vars de Dokploy (igual que JWT_SECRET);
# si falta, el contenedor cloudflared no arranca. Cópialo del dashboard de Cloudflare
# (Zero Trust → Tunnels → tu túnel → token).
CLOUDFLARE_TUNNEL_TOKEN=
