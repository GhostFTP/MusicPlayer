{
  "name": "music-server",
  "version": "1.0.0",
  "description": "Personal music streaming server",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "scan": "node src/scanner/index.js",
    "build": "cd ../music-client && npm run build && cp -r dist ../music-server/public",
    "build:prod": "npm run build && NODE_ENV=production node server.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "music-metadata": "^10.1.0"
  }
}
